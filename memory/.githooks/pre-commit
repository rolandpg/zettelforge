#!/bin/bash
#
# Pre-commit hook for A-MEM
#
# This hook enforces version control policies:
# - GPG signing encouragement
# - Conventional commit messages for version bumping
# - Prevent committing secrets
#

set -e

# Check git configuration (warning only - doesn't fail the commit)
NAME=$(git config --get user.name 2>/dev/null || true)
EMAIL=$(git config --get user.email 2>/dev/null || true)

if [ -z "$NAME" ] || [ -z "$EMAIL" ]; then
    echo "WARNING: Git user.name or user.email not configured"
    echo "Run: git config --global user.name 'Your Name'"
    echo "Run: git config --global user.email 'you@example.com'"
    echo "This commit will proceed, but consider configuring git properly."
    echo ""
fi

# Check for secrets in committed files
echo "Checking for secrets..."

# Patterns that should not be in committed files
SECRET_PATTERNS=(
    "api_key\s*=\s*['\"][^'\"]+['\"]"
    "secret\s*=\s*['\"][^'\"]+['\"]"
    "password\s*=\s*['\"][^'\"]+['\"]"
    "token\s*=\s*['\"][^'\"]+['\"]"
    "AKIA[0-9A-Z]{16}"
)

has_secrets=false
for pattern in "${SECRET_PATTERNS[@]}"; do
    if git diff --cached --name-only | xargs grep -E "$pattern" 2>/dev/null; then
        echo "WARNING: Potential secret found matching pattern: $pattern"
        echo "Please review and remove if necessary."
        has_secrets=true
    fi
done

if [ "$has_secrets" = true ]; then
    echo ""
    echo "WARNING: Potential secrets detected. Please review carefully."
    echo "Commit will proceed, but consider removing secrets."
    echo ""
fi

# Check for GPG signing (warning only)
if ! git config --get commit.gpgsign 2>/dev/null | grep -q "true"; then
    echo "WARNING: GPG signing is not enabled."
    echo "Run: git config --global commit.gpgsign true"
    echo "This commit will proceed, but consider enabling GPG signing for non-repudiation."
    echo ""
fi

echo "Pre-commit checks passed."
exit 0
