{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A-MEM Ontology Schema v1.0",
  "description": "Formal ontology definition for A-MEM knowledge graph with FIRST IEP 2.0 governance",
  "version": "1.0.0",
  "date": "2026-04-02",

  "entity_types": {
    "cve": {
      "type": "core",
      "description": "Common Vulnerabilities and Exposures identifier",
      "canonical_format": "^CVE-\\d{4}-\\d{4,}$",
      "attributes": {
        "id": {"type": "string", "required": true, "pattern": "^CVE-\\d{4}-\\d{4,}$"},
        "description": {"type": "string", "required": true},
        "cvss_score": {"type": "number", "min": 0.0, "max": 10.0},
        "severity": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
        "published_date": {"type": "string", "format": "date"},
        "last_modified": {"type": "string", "format": "date"},
        "exploit_status": {"type": "string", "enum": ["none", "poc", "active", "widespread"]},
        "affected_products": {"type": "array", "items": {"type": "string"}},
        "mitre_id": {"type": "string", "pattern": "^TA\\d{4}$", "optional": true}
      }
    },

    "actor": {
      "type": "core",
      "description": "Threat actor group or campaign",
      "canonical_format": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$",
      "attributes": {
        "name": {"type": "string", "required": true},
        "type": {"type": "string", "enum": ["apt", "lazarus", "ransomware", "script_kiddie", "insider", "other"]},
        "origin_country": {"type": "string", "optional": true},
        "first_seen": {"type": "string", "format": "date"},
        "last_seen": {"type": "string", "format": "date"},
        "motivation": {"type": "array", "items": {"type": "string", "enum": ["financial", "espionage", "sabotage", "activism", " war"]}},
        "targets": {"type": "array", "items": {"type": "string"}},
        "mitre_id": {"type": "string", "pattern": "^S\\d{4}$", "optional": true}
      }
    },

    "tool": {
      "type": "core",
      "description": "Malware, exploit toolkit, or attack tool",
      "canonical_format": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$",
      "attributes": {
        "name": {"type": "string", "required": true},
        "type": {"type": "string", "enum": ["malware", "exploit_kit", "exploit", "backdoor", "rat", "ransomware", "dropper", "loader"]},
        "language": {"type": "string", "optional": true},
        "platform": {"type": "array", "items": {"type": "string"}},
        "first_seen": {"type": "string", "format": "date"},
        "mitre_id": {"type": "string", "pattern": "^T\\d{4}$", "optional": true}
      }
    },

    "campaign": {
      "type": "core",
      "description": "Coordinated threat campaign",
      "canonical_format": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$",
      "attributes": {
        "name": {"type": "string", "required": true},
        "actor": {"type": "string", "required": true},
        "start_date": {"type": "string", "format": "date"},
        "end_date": {"type": "string", "format": "date", "optional": true},
        "targets": {"type": "array", "items": {"type": "string"}},
        "methods": {"type": "array", "items": {"type": "string"}},
        "status": {"type": "string", "enum": ["active", "disrupted", "ended", "inactive"]}
      }
    },

    "sector": {
      "type": "core",
      "description": "Target sector or industry",
      "canonical_format": "^[a-z0-9]+(?:[_-][a-z0-9]+)*$",
      "attributes": {
        "name": {"type": "string", "required": true},
        "category": {"type": "string", "enum": ["critical_infrastructure", "finance", "healthcare", "government", "technology", "education", "manufacturing", "energy", "transportation", "other"]},
        "subsectors": {"type": "array", "items": {"type": "string"}, "optional": true}
      }
    },

    "governance": {
      "type": "metadata",
      "description": "Governance metadata and policies",
      "attributes": {
        "tier": {"type": "string", "enum": ["A", "B", "C"], "required": true},
        "source_type": {"type": "string", "required": true},
        "source_ref": {"type": "string", "optional": true},
        "confidence": {"type": "number", "min": 0.0, "max": 1.0},
        "access_count": {"type": "integer", "minimum": 0},
        "last_accessed": {"type": "string", "format": "date-time"},
        "evolution_count": {"type": "integer", "minimum": 0}
      }
    },

    "iep_policy": {
      "type": "governance",
      "description": "Information Exchange Policy per FIRST IEP 2.0",
      "attributes": {
        "policy_id": {"type": "string", "pattern": "^IEP-[A-Z]{2,4}-\\d{4}$", "required": true},
        "name": {"type": "string", "required": true},
        "description": {"type": "string"},
        "version": {"type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$"},
        "hasl": {
          "type": "object",
          "required": true,
          "properties": {
            "handling": {"type": "string", "enum": ["OPEN", "RESTRICTED", "CONFIDENTIAL", "PRIVATE"], "required": true},
            "action": {"type": "string", "enum": ["READ", "WRITE", "MODERATE", "ADMIN"], "required": true},
            "sharing": {"type": "string", "enum": ["NONE", "INTERNAL", "TLP_WHITE", "TLP_GREEN", "TLP_AMBER", "TLP_RED", "COMMERCIAL"], "required": true},
            "licensing": {"type": "string", "enum": ["CC0", "CC-BY", "CC-BY-SA", "CC-BY-NC", "CC-BY-ND", "CC-BY-NC-SA", "CC-BY-NC-ND", "ALL-RIGHTS-RESERVED", "OPEN-GOVERNMENT"], "required": true}
          }
        },
        "tlp": {"type": "string", "enum": ["CLEAR", "WHITE", "GREEN", "AMBER", "RED"], "optional": true},
        "expiration": {"type": "string", "format": "date", "optional": true},
        "revocation_date": {"type": "string", "format": "date", "optional": true},
        "status": {"type": "string", "enum": ["active", "expired", "revoked", "draft"], "default": "active"},
        "applies_to_entities": {"type": "array", "items": {"type": "string"}, "optional": true},
        "created_by": {"type": "string", "required": true},
        "created_at": {"type": "string", "format": "date-time", "required": true},
        "modified_by": {"type": "string", "optional": true},
        "modified_at": {"type": "string", "format": "date-time", "optional": true}
      }
    },

    "graph_node": {
      "type": "storage",
      "description": "Base node structure for knowledge graph",
      "attributes": {
        "node_id": {"type": "string", "pattern": "^[a-z0-9]{8}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{12}$", "required": true},
        "entity_type": {"type": "string", "enum": ["cve", "actor", "tool", "campaign", "sector", "iep_policy"], "required": true},
        "entity_id": {"type": "string", "required": true},
        "properties": {"type": "object", "required": true},
        "created_at": {"type": "string", "format": "date-time", "required": true},
        "updated_at": {"type": "string", "format": "date-time", "required": true}
      }
    },

    "graph_edge": {
      "type": "storage",
      "description": "Base edge structure for knowledge graph relationships",
      "attributes": {
        "edge_id": {"type": "string", "pattern": "^[a-z0-9]{8}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{12}$", "required": true},
        "from_node_id": {"type": "string", "pattern": "^[a-z0-9]{8}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{12}$", "required": true},
        "to_node_id": {"type": "string", "pattern": "^[a-z0-9]{8}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{4}-[a-z0-9]{12}$", "required": true},
        "relationship_type": {"type": "string", "enum": [
          "USES", "TARGETS", "EXPLOITS", "MITIGATES", "GOVERNS", "APPLIES_TO",
          "RESTRICTS", "RELATED_TO", "ATTACKS", "COMPROMISES", "DROPS", "C2",
          "EXFILTRATES_TO", "INJECTS", "PERSISTS_IN", "ENCRYPTS", "DROPS_PERSISTENT"
        ], "required": true},
        "properties": {"type": "object", "optional": true},
        "created_at": {"type": "string", "format": "date-time", "required": true}
      }
    }
  },

  "relationship_types": {
    "USES": {
      "description": "Actor or campaign uses a tool",
      "cardinality": "actor -> tool (1:N)",
      "reverse": "USED_BY",
      "example": "muddywater USES cobalt_strike"
    },
    "TARGETS": {
      "description": "Actor or campaign targets a sector or organization",
      "cardinality": "actor/campaign -> sector (1:N)",
      "reverse": "TARGETED_BY",
      "example": "apt28 TARGETS government"
    },
    "EXPLOITS": {
      "description": "Tool or actor exploits a vulnerability",
      "cardinality": "tool -> cve (1:N)",
      "reverse": "EXPLOITED_BY",
      "example": "cobalt_strike EXPLOITS CVE-2024-3094"
    },
    "MITIGATES": {
      "description": "A CVE or technique is mitigated by a control",
      "cardinality": "cve -> mitigation (1:N)",
      "reverse": "MITIGATED_BY",
      "example": "CVE-2024-3094 MITIGATES_by patch_VFM-2024"
    },
    "GOVERNS": {
      "description": "IEP policy governs or restricts information",
      "cardinality": "iep_policy -> entity (1:N)",
      "reverse": "GOVERNED_BY",
      "example": "IEP-US-0001 GOVERNS muddywater"
    },
    "APPLIES_TO": {
      "description": "IEP policy applies to a specific entity",
      "cardinality": "iep_policy -> entity (1:N)",
      "reverse": "APPLIES",
      "example": "IEP-US-0001 APPLIES_TO apt28"
    },
    "RESTRICTS": {
      "description": "Policy restricts handling of information",
      "cardinality": "iep_policy -> data (1:N)",
      "reverse": "RESTRICTED_BY",
      "example": "IEP-US-0001 RESTRICTS CVE-2024-3094"
    },
    "RELATED_TO": {
      "description": "Generic related relationship between entities",
      "cardinality": "any -> any (N:N)",
      "reverse": "RELATED_TO",
      "example": "apt28 RELATED_TO Lazarus"
    },
    "ATTACKS": {
      "description": "Actor attacks a target",
      "cardinality": "actor -> target (1:N)",
      "reverse": "ATTACKED_BY",
      "example": "apt28 ATTACKS financial_sector"
    },
    "COMPROMISES": {
      "description": "Tool or actor compromises systems",
      "cardinality": "tool -> system (1:N)",
      "reverse": "COMPROMISED_BY",
      "example": "cobalt_strike COMPROMISES windows_servers"
    },
    "C2": {
      "description": "Tool communicates with C2 infrastructure",
      "cardinality": "tool -> c2 (1:N)",
      "reverse": "C2_OF",
      "example": "cobalt_strike C2 ipv4-203-0-113-1"
    },
    "EXFILTRATES_TO": {
      "description": "Data exfiltrates to external location",
      "cardinality": "system -> exfil_target (1:N)",
      "reverse": "EXFILTRATES_FROM",
      "example": "compromised_host EXFILTRATES_TO境外_ip"
    }
  },

  "iep_tlp_mapping": {
    "TLP_WHITE": {"handling": "OPEN", "sharing": "TLP_WHITE", "licensing": "CC0"},
    "TLP_GREEN": {"handling": "RESTRICTED", "sharing": "TLP_GREEN", "licensing": "CC-BY"},
    "TLP_AMBER": {"handling": "CONFIDENTIAL", "sharing": "TLP_AMBER", "licensing": "CC-BY-NC"},
    "TLP_RED": {"handling": "PRIVATE", "sharing": "TLP_RED", "licensing": "ALL-RIGHTS-RESERVED"},
    "CLEAR": {"handling": "OPEN", "sharing": "NONE", "licensing": "CC0"},
    "OPEN": {"handling": "OPEN", "sharing": "NONE", "licensing": "CC0"}
  },

  "validation_rules": {
    "cve_id_format": "^CVE-\\d{4}-\\d{4,}$",
    "mitre_id_format": {
      "actor": "^S\\d{4}$",
      "tool": "^T\\d{4}$",
      "technique": "^TA\\d{4}$"
    },
    "required_fields": {
      "cve": ["id", "description"],
      "actor": ["name", "first_seen"],
      "tool": ["name", "first_seen"],
      "campaign": ["name", "actor", "start_date"],
      "sector": ["name", "category"],
      "iep_policy": ["policy_id", "name", "description", "hasl", "created_by"]
    }
  }
}
