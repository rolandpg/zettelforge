{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "A-MEM Synthesis Layer Schema v1.0",
  "description": "Response format definitions for RAG-as-answer synthesis layer",
  "version": "1.0.0",
  "date": "2026-04-02",

  "response_formats": {
    "direct_answer": {
      "description": "Concise answer with supporting evidence",
      "schema": {
        "type": "object",
        "required": ["answer", "confidence", "sources"],
        "properties": {
          "answer": {
            "type": "string",
            "description": "Concise answer to the query"
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Confidence in the answer"
          },
          "sources": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "note_id": {"type": "string"},
                "relevance_score": {"type": "number", "minimum": 0.0, "maximum": 1.0},
                "quote": {"type": "string"}
              }
            }
          },
          "keywords": {
            "type": "array",
            "items": {"type": "string"}
          }
        }
      }
    },

    "synthesized_brief": {
      "description": "Comprehensive brief with thematic analysis",
      "schema": {
        "type": "object",
        "required": ["summary", "themes", "evidence", "confidence"],
        "properties": {
          "summary": {
            "type": "string",
            "description": "One-paragraph summary"
          },
          "themes": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "description": {"type": "string"},
                "strength": {"type": "number", "minimum": 0.0, "maximum": 1.0}
              }
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "note_id": {"type": "string"},
                "supporting": {"type": "boolean"},
                "context": {"type": "string"}
              }
            }
          },
          "confidence": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0
          }
        }
      }
    },

    "timeline_analysis": {
      "description": "Chronological analysis of events",
      "schema": {
        "type": "object",
        "required": ["timeline", "key_events", "confidence"],
        "properties": {
          "timeline": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "date": {"type": "string", "format": "date"},
                "event": {"type": "string"},
                "confidence": {"type": "number"}
              }
            }
          },
          "key_events": {
            "type": "array",
            "items": {"type": "string"}
          },
          "confidence": {"type": "number"}
        }
      }
    },

    "relationship_map": {
      "description": "Entity relationship visualization as text",
      "schema": {
        "type": "object",
        "required": ["entities", "relationships", "centrality"],
        "properties": {
          "entities": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": {"type": "string"},
                "type": {"type": "string", "enum": ["actor", "tool", "cve", "campaign", "sector"]},
                " centrality": {"type": "number"}
              }
            }
          },
          "relationships": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "from": {"type": "string"},
                "to": {"type": "string"},
                "type": {"type": "string"},
                "strength": {"type": "number"}
              }
            }
          },
          "centrality": {
            "type": "object",
            "description": "Most connected entities"
          }
        }
      }
    }
  },

  "response_metadata": {
    "description": "Metadata included with all responses",
    "properties": {
      "query_id": {"type": "string"},
      "synthesis_type": {"type": "string", "enum": ["direct_answer", "synthesized_brief", "timeline_analysis", "relationship_map"]},
      "model_used": {"type": "string"},
      "tokens_used": {"type": "integer"},
      "latency_ms": {"type": "integer"},
      "confidence_threshold": {"type": "number"},
      "sources_count": {"type": "integer"},
      "tier_filter": {
        "type": "array",
        "items": {"type": "string", "enum": ["A", "B", "C"]}
      }
    }
  },

  "validation_rules": {
    "min_sources": 1,
    "max_sources": 20,
    "min_confidence": 0.3,
    "max_summary_length": 500,
    "max_answer_length": 200
  },

  "tier_preferences": {
    "default_tier_filter": ["A", "B"],
    "strict_tier_filter": ["A"],
    "all_tier_filter": ["A", "B", "C"],
    "trustworthy_sources": ["human", "tool", "observation", "ingestion"]
  }
}
