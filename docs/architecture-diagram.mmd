     CAUSAL:::enrich
     EVOLVER:::enrich
     CONSOL:::enrich
     EI:::entity
     AR:::entity
     SQL_N:::storage
     SQL_KG:::storage
     SQL_EI:::storage
     VEC:::storage
     IC:::retrieve
     VR:::retrieve
     GR:::retrieve
     BR:::retrieve
     TB:::retrieve
     CB:::retrieve
     XE:::retrieve
     SG:::output
     SV:::output
     OBS:::observe
     OCSF:::observe
     LOG:::observe
